# LAM Teknik SaaS Blockchain Environment Configuration

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
PORT=3001
APP_NAME="LAM Teknik SaaS"
APP_VERSION=1.0.0

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=mysql://lamtek:lamtek123@localhost:3306/lamtek_db
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=lamtek
DB_PASSWORD=lamtek123
DB_DATABASE=lamtek_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=lamtek-secret-key-2025-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Hyperledger Besu Configuration
# ===========================================
BESU_RPC_URL=http://localhost:8545
BESU_WS_URL=ws://localhost:8546

# Private key for signing transactions (CHANGE IN PRODUCTION!)
# This is a development key - DO NOT USE IN PRODUCTION
BLOCKCHAIN_PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63

# Smart Contract Addresses (deploy contracts first)
AKREDITASI_CONTRACT_ADDRESS=
ASESMEN_KECUKUPAN_CONTRACT_ADDRESS=
ASESMEN_LAPANGAN_CONTRACT_ADDRESS=
DOKUMEN_IPFS_CONTRACT_ADDRESS=

# ===========================================
# IPFS Configuration
# ===========================================
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# ===========================================
# File Upload Settings
# ===========================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ===========================================
# Rate Limiting
# ===========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
