# ===========================================
# DOCUMENTATION & SWAGGER
# ===========================================
GET /api/docs
  Description: Swagger UI API documentation
  Auth: None
  Response: Interactive API documentation

GET /api/docs-json
  Description: OpenAPI JSON schema
  Auth: None
  Response: Complete OpenAPI specification

# ===========================================
# HTTP STATUS CODES
# ===========================================
# 200 OK - Request successful with response body
# 201 Created - Resource created successfully
# 204 No Content - Successful request with no response body
# 400 Bad Request - Invalid request parameters or body
# 401 Unauthorized - Missing or invalid JWT token
# 403 Forbidden - User authenticated but lacks permissions
# 404 Not Found - Resource not found
# 409 Conflict - Resource already exists or state conflict
# 422 Unprocessable Entity - Validation errors in request
# 429 Too Many Requests - Rate limit exceeded
# 500 Internal Server Error - Server error
# 502 Bad Gateway - Service unavailable
# 503 Service Unavailable - Database or dependency unavailable

# ===========================================
# ERROR RESPONSE FORMAT
# ===========================================
# Standard error response structure:
# {
#   "statusCode": 400,
#   "message": "Validation failed",
#   "error": "BAD_REQUEST",
#   "timestamp": "2025-04-04T10:30:00.000Z",
#   "path": "/api/v1/endpoint"
# }
#
# With validation errors:
# {
#   "statusCode": 422,
#   "message": "Validation failed",
#   "error": "UNPROCESSABLE_ENTITY",
#   "errors": [
#     {
#       "field": "email",
#       "message": "Invalid email format",
#       "value": "invalid-email"
#     }
#   ],
#   "timestamp": "2025-04-04T10:30:00.000Z"
# }

# ===========================================
# AUTHENTICATION
# ===========================================
# All protected endpoints require JWT token in Authorization header:
# Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Token obtained from:
# - POST /auth/login
# - POST /auth/register
# - POST /auth/refresh-token (to refresh expired token)
#
# Token expires in: 24 hours (JWT_EXPIRES_IN)
# Refresh token expires in: 7 days (JWT_REFRESH_EXPIRES_IN)

# ===========================================
# PAGINATION
# ===========================================
# For endpoints that return lists, use query parameters:
# - page: Page number (starts at 1, default: 1)
# - limit: Items per page (default: 10, max: 100)
# - sort: Sort field and direction (e.g., "createdAt:desc", default: "createdAt:desc")
# - search: Search query for text fields
#
# Example: GET /users?page=2&limit=20&sort=createdAt:asc&search=john
#
# Paginated response structure:
# {
#   "data": [...],
#   "total": 150,
#   "page": 2,
#   "limit": 20,
#   "totalPages": 8,
#   "hasNextPage": true,
#   "hasPreviousPage": true
# }

# ===========================================
# RATE LIMITING
# ===========================================
# Rate limits (default):
# - 100 requests per 60 seconds per IP
# - Headers returned:
#   - X-RateLimit-Limit: 100
#   - X-RateLimit-Remaining: 99
#   - X-RateLimit-Reset: 1234567890 (Unix timestamp)
#
# When limit exceeded: HTTP 429 Too Many Requests

# ===========================================
# REQUEST/RESPONSE HEADERS
# ===========================================
# Required headers:
# - Content-Type: application/json (for JSON requests)
# - Authorization: Bearer {token} (for protected endpoints)
#
# Optional headers:
# - X-Request-ID: Unique request identifier for tracing
# - Accept: application/json
#
# Response headers:
# - Content-Type: application/json
# - X-Response-Time: Processing time in milliseconds
# - X-Request-ID: Echo of request ID if provided

# ===========================================
# FILE UPLOAD
# ===========================================
# File upload endpoints accept multipart/form-data:
# - POST /dokumen (upload document)
# - POST /ipfs/upload (upload to IPFS)
#
# Allowed file types:
# - Documents: pdf, doc, docx, xls, xlsx (max: 50MB)
# - Images: jpg, jpeg, png (max: 10MB)
#
# Example CURL:
# curl -X POST http://localhost:3000/api/v1/dokumen \
#   -H "Authorization: Bearer {token}" \
#   -F "file=@document.pdf" \
#   -F "type=surat_pendaftaran" \
#   -F "akreditasiId=123"

# ===========================================
# BLOCKCHAIN INTEGRATION
# ===========================================
# Blockchain operations:
# - Akreditasi records stored on blockchain for immutability
# - Asesmen data hashed and verified on chain
# - Document hashes stored in IPFS with blockchain references
#
# Contract addresses configured in .env:
# - AKREDITASI_CONTRACT_ADDRESS
# - ASESMEN_KECUKUPAN_CONTRACT_ADDRESS
# - ASESMEN_LAPANGAN_CONTRACT_ADDRESS
# - DOKUMEN_IPFS_CONTRACT_ADDRESS
#
# Get deployed contracts:
# GET /blockchain/contracts
#
# Verify blockchain records:
# POST /blockchain/verify/{recordHash}

# ===========================================
# IPFS INTEGRATION
# ===========================================
# IPFS gateway: http://localhost:8080/ipfs/{hash}
# IPFS API: http://localhost:5001
#
# Operations:
# - Upload files to IPFS via /ipfs/upload
# - Pin important files for permanence
# - Store document hashes in blockchain for verification
#
# Each uploaded file returns IPFS hash (CID)
# Files are accessible via gateway URL

# ===========================================
# TIMESTAMPS
# ===========================================
# All timestamps in response are ISO 8601 format (UTC):
# Example: "2025-04-04T10:30:00.000Z"
#
# Supported timestamp fields in responses:
# - createdAt: When resource was created
# - updatedAt: When resource was last modified
# - deletedAt: When resource was soft-deleted
# - submittedAt: When submission was made
# - verifiedAt: When verification was completed

# ===========================================
# DATABASE SYNCHRONIZATION
# ===========================================
# Initial setup:
# 1. Database migrations run automatically on container start
#    - Script: ./scripts/docker-start.sh
#    - Command: npm run migration:run
#
# 2. Generate new migration after schema change:
#    npm run migration:generate -n DescribeMigration
#
# 3. Run pending migrations:
#    npm run migration:run
#
# 4. Seed initial data (optional):
#    npm run seed

# ===========================================
# ENVIRONMENT VARIABLES REQUIRED
# ===========================================
# Application:
# - NODE_ENV: development|staging|production
# - PORT: API port (default: 3000)
# - CORS_ORIGINS: Comma-separated allowed origins
#
# Database:
# - DATABASE_URL: MySQL connection string
# - DB_HOST, DB_PORT, DB_USERNAME, DB_PASSWORD, DB_DATABASE
#
# Authentication:
# - JWT_SECRET: Secret key for signing tokens
# - JWT_EXPIRES_IN: Token expiration time (default: 24h)
# - JWT_REFRESH_EXPIRES_IN: Refresh token expiration (default: 7d)
#
# Blockchain:
# - BESU_RPC_URL: Hyperledger Besu RPC endpoint
# - BLOCKCHAIN_PRIVATE_KEY: Private key for signing transactions
# - Contract addresses for all deployed contracts
#
# IPFS:
# - IPFS_API_URL: IPFS API endpoint
# - IPFS_GATEWAY_URL: IPFS gateway URL
#
# Files:
# - MAX_FILE_SIZE: Maximum upload size (default: 50MB)
# - ALLOWED_FILE_TYPES: Comma-separated MIME types

# ===========================================
# PERFORMANCE TIPS
# ===========================================
# 1. Use pagination for large result sets (limit max 100)
# 2. Cache master data responses (jenjang, klaster-ilmu, etc.)
# 3. Use search/filter parameters to reduce payload
# 4. Implement request timeout of 30 seconds
# 5. Batch operations when possible
# 6. Monitor rate limit headers to avoid 429 errors

# ===========================================
# TESTING ENDPOINTS
# ===========================================
# For development/testing:
#
# Health check: 
# GET http://localhost:3000/health
#
# Login (get JWT token):
# POST http://localhost:3000/api/v1/auth/login
# Body: { "email": "admin@lamtek.id", "password": "password" }
#
# Use returned token for subsequent requests
#
# Swagger UI:
# http://localhost:3000/api/docs
