# ===========================================
# DOKUMEN & IPFS
# ===========================================
POST /dokumen
  Description: Upload document
  Auth: Bearer Token
  FormData: file (pdf/doc/docx/xls/xlsx), akreditasiId, type
  Response: { id, fileName, fileSize, ipfsHash, createdAt }

GET /dokumen/:id
  Description: Get document info
  Auth: Bearer Token
  Response: { id, fileName, fileSize, ipfsHash, mimeType, uploadedAt }

DELETE /dokumen/:id
  Description: Delete document
  Auth: Bearer Token
  Response: { message, deletedAt }

POST /ipfs/upload
  Description: Upload file to IPFS
  Auth: Bearer Token
  FormData: file
  Response: { ipfsHash, fileName, fileSize, gateway }

GET /ipfs/:hash
  Description: Download file from IPFS
  Auth: None
  Response: File download via IPFS gateway

POST /ipfs/pin
  Description: Pin file to IPFS
  Auth: Bearer Token
  Body: { ipfsHash, pinName }
  Response: { hash, pinned, pinnedAt }

# ===========================================
# BLOCKCHAIN OPERATIONS
# ===========================================
GET /blockchain/contracts
  Description: Get deployed contract addresses
  Auth: Bearer Token
  Response: { akreditasi, asesmenKecukupan, asesmenLapangan, dokumenIpfs }

POST /blockchain/verify/:hash
  Description: Verify blockchain record
  Auth: Bearer Token
  Response: { transactionHash, blockNumber, verified, timestamp }

GET /blockchain/transaction/:txHash
  Description: Get blockchain transaction details
  Auth: Bearer Token
  Response: { hash, blockNumber, from, to, value, timestamp }

# ===========================================
# PROSES AKREDITASI
# ===========================================
POST /proses-akreditasi
  Description: Create akreditasi process
  Auth: Bearer Token
  Body: { instituteId, periode, startDate, endDate }
