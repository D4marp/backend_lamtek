  Response: { data: [{ id, akreditasi, assessor, status }], total }

GET /asesmen-kecukupan/:id
  Description: Get asesmen kecukupan details
  Auth: Bearer Token
  Response: { id, akreditasi, assessor, results, scores, status }

PATCH /asesmen-kecukupan/:id
  Description: Update asesmen kecukupan
  Auth: Bearer Token
  Body: { results, notes, status }
  Response: { id, status, updatedAt }

POST /asesmen-kecukupan/:id/finalize
  Description: Finalize asesmen kecukupan
  Auth: Bearer Token
