# LAM Teknik SaaS API Endpoints Reference
# =========================================
# Complete API endpoint documentation
# Base URL: http://localhost:3000/api/v1
# Default Content-Type: application/json
# Authentication: Bearer Token (JWT)

# ===========================================
# HEALTH & STATUS
# ===========================================
GET /health
  Description: Check API health status
  Auth: None
  Response: { status, timestamp, service, version, database, redis }

# ===========================================
# AUTHENTICATION MODULE
# ===========================================
# Register & Login
POST /auth/register
  Description: Register new user account
  Auth: None
  Body: { email, password, firstName, lastName, tenantId? }
  Response: { id, email, firstName, lastName, role, token, refreshToken, tenant }

POST /auth/login
  Description: Login with email and password
  Auth: None
  Body: { email, password }
  Response: { id, email, firstName, lastName, role, token, refreshToken, tenant, permissions }

POST /auth/refresh-token
  Description: Refresh JWT token
  Auth: Bearer Token
  Body: { refreshToken }
  Response: { token, refreshToken, expiresIn }

POST /auth/logout
  Description: Logout user session
  Auth: Bearer Token
  Response: { message, success, loggedOutAt }

GET /auth/profile
  Description: Get current logged-in user profile
  Auth: Bearer Token
  Response: { id, email, firstName, lastName, role, tenant, permissions, lastLogin }

PATCH /auth/change-password
  Description: Change current user password
  Auth: Bearer Token
  Body: { oldPassword, newPassword, confirmPassword }
  Response: { message, updatedAt }

POST /auth/forgot-password
  Description: Request password reset link
  Auth: None
  Body: { email }
  Response: { message, sentTo }

POST /auth/reset-password
  Description: Reset password with token
  Auth: None
  Body: { token, newPassword, confirmPassword }
  Response: { message, success }

# ===========================================
# USER MANAGEMENT MODULE
# ===========================================
GET /users
  Description: List all users (Admin only)
  Auth: Bearer Token (Admin)
  Query: page=1&limit=10&search=&role=&status=active&tenantId=
  Response: { data: [{ id, email, firstName, lastName, role, status, lastLogin }], total, page, hasMore }

GET /users/:id
  Description: Get specific user details
  Auth: Bearer Token
  Response: { id, email, firstName, lastName, role, status, tenant, permissions, createdAt, updatedAt }

POST /users
  Description: Create new user (Admin only)
  Auth: Bearer Token (Admin)
  Body: { email, password, firstName, lastName, role, tenantId, status }
  Response: { id, email, firstName, lastName, role, tenant, createdAt }

PATCH /users/:id
  Description: Update user information
  Auth: Bearer Token
  Body: { firstName, lastName, role, status }
  Response: { id, email, firstName, lastName, role, status, updatedAt }

DELETE /users/:id
  Description: Delete user account
  Auth: Bearer Token (Admin)
  Response: { message, deletedAt, id }

POST /users/:id/activate
  Description: Activate deactivated user
  Auth: Bearer Token (Admin)
  Response: { message, activatedAt }

POST /users/:id/deactivate
  Description: Deactivate active user
  Auth: Bearer Token (Admin)
  Response: { message, deactivatedAt }

# ===========================================
# TENANT MANAGEMENT MODULE
# ===========================================
POST /tenant
  Description: Create new tenant
  Auth: Bearer Token (Admin)
  Body: { name, slug, description, contactEmail, contactPhone }
  Response: { id, name, slug, createdAt, config }

GET /tenant
  Description: List all tenants (paginated)
  Auth: Bearer Token (Admin)
  Query: page=1&limit=10
  Response: { data: [{ id, name, slug, status, createdAt }], total, page, limit }

GET /tenant/:id
  Description: Get tenant details
  Auth: Bearer Token
  Response: { id, name, slug, description, status, users, config }

PATCH /tenant/:id
  Description: Update tenant information
  Auth: Bearer Token (Admin)
  Body: { name, description, contactEmail, contactPhone }
  Response: { id, name, slug, updatedAt }

DELETE /tenant/:id
  Description: Delete tenant (cascade delete)
  Auth: Bearer Token (Admin)
  Response: { message, deletedAt }

# ===========================================
# USER MANAGEMENT
# ===========================================
GET /users
  Description: List users (paginated)
  Auth: Bearer Token (Admin)
  Query: page=1&limit=10&role=admin&status=active
  Response: { data: [{ id, email, firstName, lastName, role, status }], total }

GET /users/:id
  Description: Get specific user
  Auth: Bearer Token
  Response: { id, email, firstName, lastName, role, status, createdAt }

PATCH /users/:id
  Description: Update user information
  Auth: Bearer Token
  Body: { firstName, lastName, email, role }
  Response: { id, email, firstName, lastName, updated }

DELETE /users/:id
  Description: Delete user account
  Auth: Bearer Token (Admin)
  Response: { message, deletedAt }

POST /users/:id/change-password
  Description: Change user password
  Auth: Bearer Token
  Body: { currentPassword, newPassword, confirmPassword }
  Response: { message, success }

# ===========================================
# AKREDITASI MODULE
# ===========================================
POST /akreditasi
  Description: Create new akreditasi record
  Auth: Bearer Token
  Body: { instituteId, periode, status, notes }
  Response: { id, instituteId, periode, status, createdAt }

GET /akreditasi
  Description: List akreditasi records
  Auth: Bearer Token
  Query: page=1&limit=10&status=pending&instituteId=xxx
  Response: { data: [{ id, institute, periode, status, grade }], total }

GET /akreditasi/:id
  Description: Get akreditasi details
  Auth: Bearer Token
  Response: { id, institute, periode, status, grade, documents, blockchain }

PATCH /akreditasi/:id
  Description: Update akreditasi status
  Auth: Bearer Token
  Body: { status, notes, grade }
  Response: { id, status, updatedAt }

POST /akreditasi/:id/submit
  Description: Submit akreditasi for evaluation
  Auth: Bearer Token
  Body: { notes, documents }
  Response: { id, status, submittedAt, blockchainHash }

# ===========================================
# ASESMEN KECUKUPAN MODULE
# ===========================================
POST /asesmen-kecukupan
