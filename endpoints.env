GET /proses-akreditasi/:id
  Description: Get process details
  Auth: Bearer Token
  Response: { id, institute, stage, timelines, progress, documents }

PATCH /proses-akreditasi/:id/progress
  Description: Update process progress
  Auth: Bearer Token
  Body: { stage, completion }
  Response: { id, stage, progress, updatedAt }

# ===========================================
# PEMBAYARAN
# ===========================================
POST /pembayaran
  Description: Create payment record
  Auth: Bearer Token
